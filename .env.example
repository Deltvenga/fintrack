# Vercel Blob (auto-injected when Blob store is linked to the project)
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=store_xxxxxxxx

# Used only for Blob webhooks — not required for this app
# BLOB_WEBHOOK_PUBLIC_KEY=

# Blob access mode: "private" (default) or "public" — must match your Blob store type
# BLOB_ACCESS=private

# Local development uses data/db.json when not on Vercel and BLOB_READ_WRITE_TOKEN is empty
